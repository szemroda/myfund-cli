{
  "name": "myfund-cli",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "bin": {
    "myfund": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.build.json",
    "verify": "npm run typecheck && npm test && npm run build && npm audit"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
